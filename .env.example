# Framie Server 환경 변수
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.
#   cp .env.example .env

# 서버 포트 (기본 3000)
PORT=3000

# Supabase (Auth / DB / Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# 배경 제거용 이미지 서버 (framie_image_server)
IMAGE_SERVER_URL=http://localhost:8001

# CORS 허용 출처 (쉼표로 구분, 프로덕션에서 반드시 설정)
# 예: ALLOWED_ORIGINS=https://framie.co.kr,https://www.framie.co.kr
ALLOWED_ORIGINS=http://localhost:5173
